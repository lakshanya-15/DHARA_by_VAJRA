// Same schema as dharaa so we use the same PostgreSQL database.
// Generator uses prisma-client-js for Node.js (JavaScript) backend.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id                 String           @id @default(uuid()) @db.Uuid
  name               String
  type               String
  category           AssetCategory    @default(SOIL_PREPARATION)
  priceperday        Decimal          @db.Decimal(10, 2)
  availability       Boolean?         @default(true)
  ownerid            String           @db.Uuid
  maintenanceDueDate DateTime?        @db.Date
  attachments        Json?            @default("[]")
  createdat          DateTime?        @default(now()) @db.Timestamp(6)
  User               User             @relation(fields: [ownerid], references: [id], onUpdate: NoAction, map: "fk_asset_owner")
  Booking            Booking[]
  MaintenanceLog     MaintenanceLog[]
  Review             Review[]
}

model MaintenanceLog {
  id          String   @id @default(uuid()) @db.Uuid
  assetid     String   @db.Uuid
  date        DateTime @db.Date
  type        String // e.g., "Oil Change", "Repair"
  cost        Decimal  @db.Decimal(10, 2)
  notes       String?
  Asset       Asset    @relation(fields: [assetid], references: [id], onUpdate: NoAction)
  createdat   DateTime? @default(now()) @db.Timestamp(6)
}

enum AssetCategory {
  SOIL_PREPARATION
  SOWING
  PLANT_PROTECTION
  HARVESTING
  TRANSPORTATION
  OTHER
}

model Booking {
  id          String         @id @default(uuid()) @db.Uuid
  bookingdate DateTime       @db.Date
  bookingTime String?        // Start time (e.g., "10:30 AM")
  status      booking_status
  farmerid          String         @db.Uuid
  assetid           String         @db.Uuid
  createdat         DateTime?      @default(now()) @db.Timestamp(6)
  Asset             Asset          @relation(fields: [assetid], references: [id], onUpdate: NoAction, map: "fk_booking_asset")
  User              User           @relation(fields: [farmerid], references: [id], onUpdate: NoAction, map: "fk_booking_farmer")
  Payment           Payment[]
  Review            Review?
  Dispute           Dispute?

  @@unique([assetid, bookingdate, bookingTime], map: "unique_asset_booking_date_time")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  phone     String    @unique
  password  String // Used for mock fallback, though SMS OTP will be primary
  role      user_role
  village   String?
  district  String?
  state     String?
  address   String?
  lat       Decimal?  @db.Decimal(10, 7)
  lng       Decimal?  @db.Decimal(10, 7)
  createdat DateTime? @default(now()) @db.Timestamp(6)
  behaviorScore Float?    @default(0)
  segment       String?   @default("NEW")
  completedBookings Int? @default(0)
  cancelledBookings Int? @default(0)
  walletBalance     Decimal?  @default(0) @db.Decimal(10, 2)
  preferredCategories Json?    @default("[]")

  Asset     Asset[]
  Booking   Booking[]
  Notification Notification[]
  Payment     Payment[]
  Transaction Transaction[]
  Review      Review[] @relation("FarmerReviews")
  OperatorReviews Review[] @relation("OperatorReviews")
  Dispute     Dispute[]
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  farmerId    String   @db.Uuid
  operatorId  String   @db.Uuid
  assetId     String?  @db.Uuid
  bookingId   String   @unique @db.Uuid
  rating      Int      @default(5)
  comment     String?
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  Farmer      User     @relation("FarmerReviews", fields: [farmerId], references: [id])
  Operator    User     @relation("OperatorReviews", fields: [operatorId], references: [id])
  Asset       Asset?   @relation(fields: [assetId], references: [id])
  Booking     Booking  @relation(fields: [bookingId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  type        transaction_type
  description String?
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  User        User     @relation(fields: [userId], references: [id])
}

enum transaction_type {
  DEPOSIT
  DEDUCTION
  REFUND
  EARNING
}

model Dispute {
  id          String   @id @default(uuid()) @db.Uuid
  bookingId   String   @unique @db.Uuid
  farmerId    String   @db.Uuid
  reason      String
  status      dispute_status @default(OPEN)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  resolvedAt  DateTime? @db.Timestamp(6)

  Booking     Booking  @relation(fields: [bookingId], references: [id])
  Farmer      User     @relation(fields: [farmerId], references: [id])
}

enum dispute_status {
  OPEN
  INVESTIGATING
  RESOLVED
  REFUNDED
}

model Payment {
  id            String   @id @default(uuid()) @db.Uuid
  bookingId     String   @db.Uuid
  amount        Decimal  @db.Decimal(10, 2)
  status        payment_status @default(PENDING)
  farmerId      String   @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  
  User          User     @relation(fields: [farmerId], references: [id])
  Booking       Booking  @relation(fields: [bookingId], references: [id])
}

enum payment_status {
  PENDING
  IN_ESCROW
  RELEASED
  REFUNDED
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userid    String    @db.Uuid
  message   String
  type      String?   @default("INFO")
  isread    Boolean?  @default(false)
  createdat DateTime? @default(now()) @db.Timestamp(6)
  User      User      @relation(fields: [userid], references: [id], onUpdate: NoAction, map: "fk_notification_user")
}

enum booking_status {
  BOOKED
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum user_role {
  FARMER
  OPERATOR
  ADMIN
}
